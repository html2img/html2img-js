{
  "name": "@html2img/client",
  "version": "1.0.0",
  "description": "Official JavaScript and TypeScript SDK for the html2img HTML-to-image API: render HTML or CSS to PNG, screenshot live URLs, generate images from templates, and export PDFs.",
  "keywords": [
    "html2img",
    "html-to-image",
    "html-to-png",
    "html-to-pdf",
    "screenshot",
    "screenshot-api",
    "url-to-image",
    "og-image",
    "open-graph",
    "image-generation",
    "pdf",
    "api-client",
    "typescript"
  ],
  "homepage": "https://html2img.com",
  "bugs": {
    "url": "https://github.com/html2img/html2img-js/issues",
    "email": "info@html2img.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/html2img/html2img-js.git"
  },
  "license": "MIT",
  "author": "html2img <info@html2img.com> (https://html2img.com)",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check": "npm run lint && npm run typecheck && npm run test",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "prepublishOnly": "npm run check && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
